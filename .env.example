# ── n8n Cloud (set these as environment variables in your n8n instance) ──────
GEMINI_API_KEY=      # Google AI Studio → aistudio.google.com
SERPER_API_KEY=     # serper.dev → free tier available

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Set this in your n8n PostgreSQL credential or connection string
DB_HOST=
DB_PORT=5432
DB_NAME=tevox_content
DB_USER=
DB_PASSWORD=

# ── Frontend (.env inside /frontend) ─────────────────────────────────────────
# Copy /frontend/.env.example → /frontend/.env
VITE_N8N_WEBHOOK_BASE=https://test.app.n8n.cloud/webhook
